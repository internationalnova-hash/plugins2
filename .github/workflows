name: Build nova plugins (macOS)

on:
  push:
    paths:
      - 'plugins2/nova-level/**'
      - 'plugins2/nova-master/**'
      - '.github/workflows/build-nova-plugins.yml'
  pull_request:
    paths:
      - 'plugins2/nova-level/**'
      - 'plugins2/nova-master/**'
      - '.github/workflows/build-nova-plugins.yml'

jobs:
  build-nova-level:
    runs-on: macos-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup dependencies
        run: |
          if ! command -v cmake &> /dev/null; then
            brew install cmake
          fi

      - name: Build with CMake (if available)
        if: hashFiles('plugins2/nova-level/CMakeLists.txt') != ''
        run: |
          mkdir -p plugins2/nova-level/build
          cd plugins2/nova-level/build
          cmake .. -DCMAKE_BUILD_TYPE=Release
          cmake --build . --config Release

      - name: Build with Xcode (if available)
        if: hashFiles('plugins2/nova-level/*.xcodeproj') != ''
        run: |
          PROJECT_PATH=$(find plugins2/nova-level -name '*.xcodeproj' | head -n 1)
          if [ -n "$PROJECT_PATH" ]; then
            xcodebuild -project "$PROJECT_PATH" -scheme nova-level build -configuration Release
          fi

      - name: Build with Makefile (if available)
        if: hashFiles('plugins2/nova-level/Makefile') != ''
        run: |
          cd plugins2/nova-level
          make clean || true
          make

  build-nova-master:
    runs-on: macos-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Setup dependencies
        run: |
          if ! command -v cmake &> /dev/null; then
            brew install cmake
          fi

      - name: Build with CMake (if available)
        if: hashFiles('plugins2/nova-master/CMakeLists.txt') != ''
        run: |
          mkdir -p plugins2/nova-master/build
          cd plugins2/nova-master/build
          cmake .. -DCMAKE_BUILD_TYPE=Release
          cmake --build . --config Release

      - name: Build with Xcode (if available)
        if: hashFiles('plugins2/nova-master/*.xcodeproj') != ''
        run: |
          PROJECT_PATH=$(find plugins2/nova-master -name '*.xcodeproj' | head -n 1)
          if [ -n "$PROJECT_PATH" ]; then
            xcodebuild -project "$PROJECT_PATH" -scheme nova-master build -configuration Release
          fi

      - name: Build with Makefile (if available)
        if: hashFiles('plugins2/nova-master/Makefile') != ''
        run: |
          cd plugins2/nova-master
          make clean || true
          make
